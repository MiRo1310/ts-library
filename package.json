  },
  "homepage": "https://github.com/MiRo1310/ts-library#readme",
  "resolutions": {
    "picomatch": "^4.0.4",
    "brace-expansion": "^1.1.13",
    "flatted": "^3.4.2",
    "minimatch": "^10.2.3"
  }
}
